{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": false,
  "extends": [
    "config:recommended"
  ],
  "git-submodules": {
    "enabled": true
  },
  "automerge": true,
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "git-submodules"
      ],
      "schedule": [
        "on the first day of the month"
      ],
      "addLabels": [
        "submodules"
      ]
    }
  ]
}